    <div class="toast-wrapper">
  <% if(success && success.length > 0){ %>
    <div class="custom-toast success-toast show-toast">
      <i class="fa-solid fa-circle-check me-2"></i>
      <span><%= success %></span>
    </div>
  <% } %>

  <% if(error && error.length > 0){ %>
